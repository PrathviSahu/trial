# .dockerignore for the project
# Exclude version control
.git
.gitignore

# Maven / Java build artifacts
target/
*.class
*.jar
*.war
*.ear
*.iml
.idea/

# Node / React artifacts
node_modules/
/build/
/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# Logs
logs/

# Docker files you don’t want in the image
Dockerfile.dev
docker-compose.override.yml
